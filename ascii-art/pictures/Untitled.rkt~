#lang racket

(define (tree? t)
  (cond
    [(equal? t 'empty) #t]
    [(and (list? t)
          (= (length t) 4)
          (equal? (first t) 'node)
          (number? (second t))
          (tree? (third t))
          (tree? (fourth t)))
     #t]
    [_ #f]))

