#!/bin/sh
# Build puffincc (the Puffin compiler written in Puffin), stage 1:
# regenerate the manifest/prelude data, concatenate puffincc-src/ in
# order, and compile it with the Racket-hosted Puffin compiler.
#
#   bin/build-puffincc [out]     default out: build/puffincc
set -e
cd "$(dirname "$0")/.."
OUT="${1:-build/puffincc}"
mkdir -p build
racket src/gen-puffincc-tables.rkt
cat puffincc-src/*.puf > build/puffincc.puf
echo "concatenated $(wc -l < build/puffincc.puf | tr -d ' ') lines -> build/puffincc.puf"
bin/puffin -c -o "$OUT" build/puffincc.puf
echo "stage-1 puffincc at $OUT"
