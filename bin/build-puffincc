#!/bin/sh
# Build puffincc (the Puffin compiler written in Puffin), stage 1:
# compile its module DAG (puffincc-src/main.puf) with the
# Racket-hosted Puffin compiler. The generated modules (tables.puf,
# prelude-data.puf) are committed; regenerate them with
# `racket src/gen-puffincc-tables.rkt` after editing src/stdlib.rkt
# or src/prelude.puf.
#
#   bin/build-puffincc [out]     default out: build/puffincc
#
# After stage 1, puffincc is self-hosting and self-contained:
#   build/puffincc prog.puf -o prog                          # compile + link
#   build/puffincc puffincc-src/main.puf -o build/puffincc2  # stage 2
set -e
cd "$(dirname "$0")/.."
OUT="${1:-build/puffincc}"
mkdir -p build
racket src/gen-puffincc-tables.rkt
# stage 1 builds at -O0: at -O1 the open-coded primitives on a
# program this size produce ~90MB of assembly and the system
# assembler grinds (docs/OPTIMIZER.md "big programs" note); puffincc's
# OUTPUT optimization level is independent of how it was built
bin/puffin -c -O 0 -o "$OUT" puffincc-src/main.puf
echo "stage-1 puffincc at $OUT"
