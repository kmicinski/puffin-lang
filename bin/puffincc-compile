#!/bin/sh
# Compile one Puffin program with puffincc and link it:
#   bin/puffincc-compile prog.puf out [target]
set -e
cd "$(dirname "$0")/.."
PROG="$1"; OUT="$2"; TARGET="${3:-arm64}"
CC="${CC:-/usr/bin/clang}"
case "$TARGET" in
  x86-64) TRIPLE="x86_64-apple-darwin";;
  *)      TRIPLE="arm64-apple-darwin";;
esac
{ echo "(target $TARGET)"; cat "$PROG"; } | build/puffincc > "$OUT.s"
$CC -target "$TRIPLE" -Wall -O2 -c "$OUT.s" -o "$OUT.o"
$CC -target "$TRIPLE" -Wl,-stack_size,0x20000000 "$OUT.o" src/runtime/libpuffin.a -o "$OUT"
