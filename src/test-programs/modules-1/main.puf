(require "vec.puf")
(require "table.puf" #:as T)
(require "util.puf" #:only (twice compose) #:rename ((twice do-twice)))
(println (dot (list 1 2 3) (list 4 5 6)))
(println (norm2 (list 3 4)))
(println (T.size (list 1 2)))
(println (T.lookup (list (cons 'a 1) (cons 'b 2)) 'b))
(println (T.classify (list 'vec 7 8)))
(println (do-twice (lambda (x) (* x x)) 3))
(println ((compose (lambda (x) (+ x 1)) (lambda (x) (* x 10))) 4))
;; own len wins over the module's un-imported one; prelude length intact
(define (len l) 999)
(println (len (list 1 2)))
(println (length (list 1 2 3)))
