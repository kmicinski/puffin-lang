;; qualified-only import target; defines its own `length` (module-
;; private shadow of the prelude) and matches on cross-module data
(provide size lookup classify)
(define (length l) 1000000)
(define (size t) (length t))
(define (lookup t k)
  (match t
    ['() #f]
    [`((,k2 . ,v) . ,rest) (if (eq? k k2) v (lookup rest k))]))
(define (classify v)
  (match v
    [`(vec ,xs ...) (cons 'vector-of xs)]
    [(? number? n) 'num]
    [_ 'other]))
