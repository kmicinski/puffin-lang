;; the CIS352 classic, in three modules: compile arithmetic
;; expressions to a stack machine (compiler.puf), run the machine
;; (vm.puf), and check both against direct evaluation
(require "compiler.puf")
(require "vm.puf")
(define (direct e)
  (match e
    [(? fixnum? n) n]
    [`(+ ,a ,b) (+ (direct a) (direct b))]
    [`(- ,a ,b) (- (direct a) (direct b))]
    [`(* ,a ,b) (* (direct a) (direct b))]
    [`(neg ,a) (- (direct a))]))
(define tests
  '((+ 1 2)
    (* (+ 1 2) (- 10 4))
    (neg (* 3 (+ 4 5)))
    (- (* (* 2 3) (* 4 5)) (+ (+ 1 2) 3))
    (* (neg 7) (- 2 9))))
(for-each-check tests)
(define (for-each-check ts)
  (match ts
    ['() 'all-agree]
    [(cons t rest)
     (let ([c (run-vm (compile-expr t) '())] [d (direct t)])
       (println (list t '=> c (if (eq? c d) 'ok 'MISMATCH)))
       (for-each-check rest))]))
(println (compile-expr '(* (+ 1 2) 3)))
(run-vm (compile-expr '(* (+ 1 2) (- 10 4))) '())
