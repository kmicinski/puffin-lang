;; modules-typed: a type is a first-class module citizen. This module
;; PROVIDES the type name Shape alongside its constructors; importers
;; may then write [s : Shape] (or [s : S.Shape] under #:as) and the
;; annotation means exactly what it says (docs/MODULES.md).
(provide Shape Point Circle Rect area)

(define-type Shape
  (Point)
  (Circle Int)
  (Rect Int Int))

(define (area [s : Shape]) : Int
  (match s
    [Point 0]
    [(Circle r) (* 3 (* r r))]
    [(Rect w h) (* w h)]))
