 (assign make-closure9608 (make-closure 2)) (seq (assign clo9559 make-closure9608) (seq (assign funref9609 (fun-ref lam9557)) (seq (unsafe-vector-set! clo9559 0 funref9609) (seq (unsafe-vector-set! clo9559 1 x) (return clo9559)))))))) (defn (lam9557 env9558 y) (|+9611| env9558 uref9610 x y) ((lam9557 seq (assign uref9610 (unsafe-vector-ref env9558 1)) (seq (assign x uref9610) (seq (assign |+9611| (+ x y)) (return |+9611|)))))))
)
