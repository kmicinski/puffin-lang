;; rebuild the locals-program: substitute the string table back in,
;; alists -> immutable hashes, locals lists -> sets
(define (tb-unstring v strs)
  (match v
    [`(%string ,i) (list-ref strs i)]
    [(cons a d) (cons (tb-unstring a strs) (tb-unstring d strs))]
    [_ v]))

(define (tb-al->hash al)
  (foldl (lambda (kv acc) (hash-set acc (car kv) (cdr kv))) (hash) al))

(define (tb-mk-program ser strs)
  (match (tb-unstring ser strs)
    [`(program ,info-al ,defs ...)
     `(program ,(tb-al->hash info-al)
               ,@(map (lambda (d)
                        (match d
                          [`(defn (,f ,args ...) ,locals ,blocks-al)
                           `(define ,(list->set locals) (,f ,@args)
                              ,(tb-al->hash blocks-al))]))
                      defs))]))

(define (tb-run-x86 p)
  (render-x86
   (prelude-and-conclusion-x86
    (patch-instructions-x86
     (allocate-registers-x86
      (select-instructions-x86 p))))))

(define (tb-run-arm64 p)
  (render-arm64
   (prelude-and-conclusion-arm64
    (patch-instructions-arm64
     (allocate-registers-arm64
      (select-instructions-arm64 p))))))

(define (tb-section name body)
  (display "=== BEGIN ")
  (display name)
  (display " ===\n")
  (display body)
  (display "=== END ")
  (display name)
  (display " ===\n"))

(set! current-target 'x86-64)
(tb-section "x86 test1" (tb-run-x86 (tb-mk-program test-input-1 test-strings-1)))
(tb-section "x86 test2" (tb-run-x86 (tb-mk-program test-input-2 test-strings-2)))
(tb-section "x86 test3" (tb-run-x86 (tb-mk-program test-input-3 test-strings-3)))
(set! current-target 'arm64)
(tb-section "arm64 test1" (tb-run-arm64 (tb-mk-program test-input-1 test-strings-1)))
(tb-section "arm64 test2" (tb-run-arm64 (tb-mk-program test-input-2 test-strings-2)))
(tb-section "arm64 test3" (tb-run-arm64 (tb-mk-program test-input-3 test-strings-3)))
