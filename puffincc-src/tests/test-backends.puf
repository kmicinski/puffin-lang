;; puffincc -- tests/test-backends.puf: drive the backends on
;; locals-program inputs captured from the Racket frontend
;; (src/compile.rkt passes through uncover-locals, serialized with
;; sets->sorted lists, hashes->sorted alists, and -- since Puffin
;; quote can't carry string data -- string literals pulled out into
;; a (list ...) table with (%string i) placeholders).
;;
;; Run: cat puffincc-src/00-tables.puf puffincc-src/02-system.puf \
;;          puffincc-src/05-backends.puf puffincc-src/tests/test-backends.puf \
;;          > /tmp/tb.puf && bin/puffin -i /tmp/tb.puf
;;
;; test 1: factorial (recursion, tail calls, closures, comparisons)
;; test 2: globals + set!, a variadic defn, register pressure/spills,
;;         a returned closure, string + symbol literals, stdlib prims
;; test 3: enough register pressure to spill on both targets

(define test-strings-1
  (list)
)
(define test-input-1
  '(program ((globals . 0)) (defn (main) (clo9537 funref9543 make-closure9542 ret9554 uref9544 v9538) ((main seq (assign make-closure9542 (make-closure 1)) (seq (assign v9538 make-closure9542) (seq (assign funref9543 (fun-ref fact)) (seq (unsafe-vector-set! v9538 0 funref9543) (seq (assign clo9537 v9538) (seq (assign uref9544 (unsafe-vector-ref clo9537 0)) (seq (assign ret9554 (app uref9544 clo9537 10 1)) (return ret9554)))))))))) (defn (fact env9539 n acc) (*9552 |+9551| |-9550| <9546 acc clo9540 env9539 funref9548 make-closure9547 n uref9549 v9541) ((fact seq (assign <9546 (< n 1)) (if (eq? <9546 #f) (goto lab9556) (goto lab9555))) (lab9555 return acc) (lab9556 seq (assign make-closure9547 (make-closure 1)) (seq (assign v9541 make-closure9547) (seq (assign funref9548 (fun-ref fact)) (seq (unsafe-vector-set! v9541 0 funref9548) (seq (assign clo9540 v9541) (seq (assign uref9549 (unsafe-vector-ref clo9540 0)) (seq (assign |-9550| (- 1)) (seq (assign |+9551| (+ n |-9550|)) (seq (assign *9552 (* n acc)) (tail-app 3 uref9549 clo9540 |+9551| *9552)))))))))))))
)

