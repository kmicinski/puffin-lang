;;
;; GENERATED by the validation harness (scratchpad middle-harness.rkt):
;; each input below is the true previous-stage IR produced by the
;; Racket reference chain (src/compile.rkt) on a small source program.
;; Run:
;;   cat puffincc-src/00-tables.puf puffincc-src/02-system.puf \
;;       puffincc-src/04-middle.puf puffincc-src/tests/test-middle.puf \
;;     > /tmp/tm.puf && bin/puffin -i /tmp/tm.puf
;; Each test prints a TEST:<tag> line followed by one canonical value
;; (block hashes as CFG-ordered assoc lists with normalized labels;
;; sets as sorted lists). The harness compares every value against
;; the reference output modulo a bijection of gensym'd names.

(define (tm-show-info p)
  (list (hash-ref (program-info p) 'globals) (program-defns p)))

(define (tm-tail-targets t)
  (match t
    [`(seq ,_ ,rst) (tm-tail-targets rst)]
    [`(goto ,l) (list l)]
    [`(if ,_ (goto ,l1) (goto ,l2)) (list l1 l2)]
    [_ '()]))

(define (tm-bfs entry blocks)
  (let loop ([queue (list entry)] [seen (set)] [order '()])
    (match queue
      ['() (reverse order)]
      [`(,l . ,rst)
       (if (set-member? seen l)
           (loop rst seen order)
           (loop (append rst (tm-tail-targets (hash-ref blocks l)))
                 (set-add seen l)
                 (cons l order)))])))

(define (tm-canon-blocks entry blocks)
  (define order (tm-bfs entry blocks))
  (define ren
    (let loop ([ls order] [i 0] [acc (hash)])
      (match ls
        ['() acc]
        [`(,l . ,rst)
         (loop rst (+ i 1)
               (hash-set acc l
                         (string->symbol
                          (string-append "blk" (string-append (number->string i) "z")))))])))
  (define (ren-tail t)
    (match t
      [`(seq ,s ,rst) `(seq ,s ,(ren-tail rst))]
      [`(goto ,l) `(goto ,(hash-ref ren l))]
      [`(if ,c (goto ,l1) (goto ,l2))
       `(if ,c (goto ,(hash-ref ren l1)) (goto ,(hash-ref ren l2)))]
      [t t]))
  (map (lambda (l) (list (hash-ref ren l) (ren-tail (hash-ref blocks l)))) order))

(define (tm-show-blocks p)
  (map (lambda (d)
         (match d
           [`(define (,f ,xs ...) ,blocks)
            (list f xs (hash-count blocks) (tm-canon-blocks f blocks))]))
       (program-defns p)))

(define (tm-show-locals p)
  (map (lambda (d)
         (match d
           [`(define ,locals (,f ,xs ...) ,blocks)
            (list f xs (sort (set->list locals) symbol<?) (hash-count blocks))]))
       (program-defns p)))

