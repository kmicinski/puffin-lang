".globl _main\n.extern _read_int64\n.extern _print_int64\n_main:\n    pushq %rbp\n    movq %rsp, %rbp\n    addq $-16, %rsp\n    movq $2, -24(%rbp)\n    movq -24(%rbp), %rax\n    movq %rax, -16(%rbp)\n    movq -16(%rbp), %rax\n    movq %rax, -8(%rbp)\n    movq -8(%rbp), %rax\n    movq %rax, %rdi\n    call _print_int64\n    movq $0, %rax\n    movq %rbp, %rsp\n    popq %rbp\n    ret\n"
